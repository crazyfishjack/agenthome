# Docker 构建忽略文件
# 这些文件/目录不会被复制到 Docker 镜像中

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 前端构建产物
frontend/dist/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Docker
docker/
Dockerfile*
docker-compose*

# 数据文件（通过 volume 挂载）
data/
*.db
*.db-shm
*.db-wal

# 日志
logs/
*.log

# 测试
tests/
test/
.pytest_cache/
.coverage

# 其他
output/
*.tmp
*.temp
